<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Conduct Inspection – FSSAI Inspector Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/startInspection.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<script>
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(async position => {
      const lat = position.coords.latitude;
      const lon = position.coords.longitude;
      document.getElementById('latitude').value = lat;
      document.getElementById('longitude').value = lon;

      // Perform Reverse Geocoding to get human-readable address
      try {
        const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`);
        const data = await response.json();
        if (data && data.display_name) {
          const addressOutput = document.getElementById('gps-address-output');
          if (addressOutput) {
            addressOutput.innerHTML = `<strong>Detected Location:</strong> ${data.display_name}`;
            addressOutput.style.color = '#10b981'; // Success Green
          }
        }
      } catch (e) {
        console.warn('Reverse geocoding failed', e);
      }
    }, err => {
      console.warn('Geolocation permission denied or failed.', err);
    });
  }
</script>

<body>

  <%- include('partials/header2') %>

    <div class="form-wrapper">
      <div class="top-header">
        <div>
          <h1>Conduct Inspection</h1>
          <p>Complete the hygiene inspection checklist</p>
        </div>
        <div style="text-align: right;">
          <span class="badge <%= scoreBadge %>">Manual Score: <%= hygieneScore %>/5.0</span>
        </div>
      </div>

      <form action="/inspection/submit/<%= inspection.id %>" method="POST" enctype="multipart/form-data">
        <input type="hidden" name="auto_score" id="auto_score_input" value="0.00">

        <!-- Restaurant Info -->
        <div class="card">
          <div class="card-header">
            <i data-lucide="building-2" class="icon blue"></i>
            <div>
              <h2>
                <%= restaurant.name %>
              </h2>
              <p>License: <%= restaurant.license_number %>
              </p>
            </div>
          </div>
          <div class="card-content">
            <p><i data-lucide="map-pin"></i>
              <%= restaurant.address %>
            </p>
            <p><i data-lucide="phone"></i>
              <%= restaurant.phone %>
            </p>
            <p><i data-lucide="mail"></i>
              <%= restaurant.email %>
            </p>
            <p><i data-lucide="calendar"></i> Scheduled: <%= inspection.scheduled_date %>
            </p>
          </div>
        </div>

        <!-- Checklist -->
        <% Object.entries(checklistSchema).forEach(([section, items])=> { %>
          <div class="card">
            <div class="card-header">
              <h3>
                <%= sectionLabels[section] %>
              </h3>
              <p>Check all items that meet the hygiene standards</p>
            </div>
            <div class="card-content">
              <% Object.entries(items).forEach(([key, label])=> { %>
                <label class="checkbox-row">
                  <input type="checkbox" name="checklist[<%= section %>][<%= key %>]" class="hygiene-checkbox"
                    data-weight="<%= checklistWeights[section][key] %>" />
                  <span>
                    <%= label %>
                  </span>
                </label>
                <% }) %>
            </div>
          </div>
          <% }) %>

            <!-- Notes -->
            <div class="card">
              <div class="card-header">
                <h3>Additional Notes</h3>
                <p>Add any observations or recommendations</p>
              </div>
              <div class="card-content">
                <textarea name="notes" rows="5" placeholder="Enter notes..."></textarea>
              </div>
            </div>

            <div class="location-card">
              <h3>📍 Inspection Location Audit</h3>
              <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 12px;">Your current GPS location is
                permanently recorded against this inspection report.</p>
              <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                <div class="location-group" style="flex: 1;">
                  <label for="latitude">Latitude</label>
                  <input type="text" id="latitude" name="latitude" readonly style="background: #f1f5f9;" />
                </div>
                <div class="location-group" style="flex: 1;">
                  <label for="longitude">Longitude</label>
                  <input type="text" id="longitude" name="longitude" readonly style="background: #f1f5f9;" />
                </div>
              </div>
              <p id="gps-address-output" style="font-size: 0.95rem; color: #f59e0b;">Fetching live address from
                satellite...</p>
            </div>


            <div class="form-group">

            </div>

            <!-- Images -->
            <div class="card">
              <div class="card-header">
                <h3>Supporting Images</h3>
                <p>Upload photos for your inspection</p>
              </div>
              <div class="card-content drop-area">
                <i data-lucide="camera" class="icon large gray"></i>
                <p>Click to upload or drag and drop</p>
                <!-- Live Camera Integration Component -->
                <div id="live-camera-module"
                  style="display: none; background: #000; border-radius: 12px; overflow: hidden; position: relative; width: 100%; margin-top: 16px; margin-bottom: 16px;">
                  <video id="camera-stream" autoplay playsinline
                    style="width: 100%; height: auto; display: block;"></video>
                  <button type="button" id="webrtc-capture-btn"
                    style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: #ef4444; color: white; border: 4px solid rgba(255,255,255,0.4); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.5); z-index: 10;">
                    <i data-lucide="camera" style="width: 24px; height: 24px;"></i>
                  </button>
                  <button type="button" id="webrtc-close-btn"
                    style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.5); color: white; border: none; padding: 8px; border-radius: 8px; cursor: pointer; z-index: 10;">
                    Done
                  </button>
                </div>

                <canvas id="camera-canvas" style="display: none;"></canvas>

                <!-- Thumbnail Gallery -->
                <div id="camera-gallery"
                  style="display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px; margin-top: 16px;">
                </div>

                <input type="file" name="images" id="cameraInput" multiple accept="image/*" style="display: none;" />

                <div style="display: flex; gap: 12px; margin-top: 12px;">
                  <button type="button" class="btn primary" id="open-live-camera-btn" style="flex: 1;">
                    🔴 Open Live Camera
                  </button>
                  <button type="button" class="btn outline" onclick="document.getElementById('cameraInput').click()"
                    style="flex: 1;">
                    📁 Select from Gallery
                  </button>
                </div>
              </div>
            </div>

            <!-- Live Auto-Score Summary -->
            <div
              style="background: #f8fafc; border: 2px solid #e2e8f0; border-radius: 12px; padding: 20px; margin-bottom: 16px; text-align: center;">
              <p
                style="font-size: 0.85rem; color: #64748b; margin-bottom: 8px; font-weight: 500; text-transform: uppercase; letter-spacing: 0.05em;">
                Standardized Auto-Score</p>
              <div id="live-auto-score-badge"
                style="display: inline-block; background: #6366f1; color: white; padding: 10px 28px; border-radius: 99px; font-size: 1.4rem; font-weight: 700; box-shadow: 0 4px 12px rgba(99,102,241,0.3); transition: background 0.3s;">
                <span id="live-auto-score-value">0.00</span> / 5.0
              </div>
              <p style="font-size: 0.8rem; color: #94a3b8; margin-top: 8px;">Updates live as you check items above</p>
            </div>

            <!-- Submit -->
            <div class="submit-actions">
              <button type="button" class="btn outline" onclick="window.history.back()">Cancel</button>
              <button type="submit" class="btn primary">
                <i data-lucide="check-circle"></i> Submit Report
              </button>
            </div>

      </form>

    </div>

    <script>
      lucide.createIcons();

      // WebRTC Live Camera Logic
      const openLiveCameraBtn = document.getElementById('open-live-camera-btn');
      const liveCameraModule = document.getElementById('live-camera-module');
      const cameraStream = document.getElementById('camera-stream');
      const captureBtn = document.getElementById('webrtc-capture-btn');
      const closeBtn = document.getElementById('webrtc-close-btn');
      const canvas = document.getElementById('camera-canvas');
      const cameraInput = document.getElementById('cameraInput');
      const gallery = document.getElementById('camera-gallery');

      let mediaStream = null;
      let capturedFiles = [];

      async function startCamera() {
        try {
          mediaStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
          cameraStream.srcObject = mediaStream;
          liveCameraModule.style.display = 'block';
          openLiveCameraBtn.style.display = 'none';
        } catch (err) {
          alert('Could not access camera. Please check your browser permissions.');
          console.error(err);
        }
      }

      // --- Phase 8: Auto Scoring Logic ---
      const checkboxes = document.querySelectorAll('.hygiene-checkbox');
      const liveScoreValue = document.getElementById('live-auto-score-value');
      const autoScoreInput = document.getElementById('auto_score_input');
      const TOTAL_MAX_POINTS = 85; // Sum of all weights: 10 + 10 + 30 + 15 + 20

      function calculateLiveScore() {
        let totalPoints = 0;
        checkboxes.forEach(cb => {
          if (cb.checked) {
            totalPoints += parseInt(cb.dataset.weight || 0);
          }
        });
        const calculated = (totalPoints / TOTAL_MAX_POINTS) * 5;
        const finalScore = calculated.toFixed(2);

        liveScoreValue.innerText = finalScore;
        autoScoreInput.value = finalScore;

        // Change color based on score
        const badge = document.getElementById('live-auto-score-badge');
        if (calculated >= 4) badge.style.background = '#10b981';
        else if (calculated >= 2.5) badge.style.background = '#f59e0b';
        else badge.style.background = '#ef4444';
      }

      checkboxes.forEach(cb => {
        cb.addEventListener('change', calculateLiveScore);
      });

      // Initialize
      calculateLiveScore();

      function stopCamera() {
        if (mediaStream) {
          mediaStream.getTracks().forEach(track => track.stop());
          mediaStream = null;
        }
        liveCameraModule.style.display = 'none';
        openLiveCameraBtn.style.display = 'block';
      }

      function updateFileInput() {
        const dt = new DataTransfer();
        capturedFiles.forEach(file => dt.items.add(file));
        cameraInput.files = dt.files;
      }

      function addThumbnail(file) {
        const wrapper = document.createElement('div');
        wrapper.style.position = 'relative';

        const img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.style.width = '100%';
        img.style.height = '80px';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '8px';
        img.style.border = '1px solid #e2e8f0';

        const removeBtn = document.createElement('button');
        removeBtn.innerHTML = '×';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '-5px';
        removeBtn.style.right = '-5px';
        removeBtn.style.background = '#ef4444';
        removeBtn.style.color = 'white';
        removeBtn.style.border = 'none';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.width = '20px';
        removeBtn.style.height = '20px';
        removeBtn.style.display = 'flex';
        removeBtn.style.alignItems = 'center';
        removeBtn.style.justifyContent = 'center';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.fontSize = '14px';

        removeBtn.onclick = () => {
          capturedFiles = capturedFiles.filter(f => f !== file);
          updateFileInput();
          wrapper.remove();
        };

        wrapper.appendChild(img);
        wrapper.appendChild(removeBtn);
        gallery.appendChild(wrapper);
      }

      openLiveCameraBtn.addEventListener('click', startCamera);
      closeBtn.addEventListener('click', stopCamera);

      captureBtn.addEventListener('click', () => {
        canvas.width = cameraStream.videoWidth;
        canvas.height = cameraStream.videoHeight;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(cameraStream, 0, 0, canvas.width, canvas.height);

        // --- Phase 8: Image Quality Guardrail ---
        const quality = ImageQualityGuard.analyze(canvas);
        if (!quality.isGood) {
          if (!confirm(`${quality.reason}\n\nDo you want to keep it anyway?`)) {
            return; // Cancel capture
          }
        }

        canvas.toBlob(blob => {
          const file = new File([blob], `inspection_snapshot_${Date.now()}.jpg`, { type: 'image/jpeg' });
          capturedFiles.push(file);
          updateFileInput();
          addThumbnail(file);

          // Visual feedback
          captureBtn.style.background = '#10b981';
          setTimeout(() => captureBtn.style.background = '#ef4444', 300);
        }, 'image/jpeg', 0.9);
      });
    </script>
    <script src="/js/imageQualityGuard.js"></script>
</body>

</html>