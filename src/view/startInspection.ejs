<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8" />
  <title>Conduct Inspection – FSSAI Inspector Hub</title>
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <link rel="stylesheet" href="/css/startInspection.css" />
  <script src="https://unpkg.com/lucide@latest"></script>
</head>
<script>
  if (navigator.geolocation) {
    navigator.geolocation.getCurrentPosition(async position => {
      const lat = position.coords.latitude;
      const lon = position.coords.longitude;
      document.getElementById('latitude').value = lat;
      document.getElementById('longitude').value = lon;

      // Perform Reverse Geocoding to get human-readable address
      try {
        const response = await fetch(`https://nominatim.openstreetmap.org/reverse?format=json&lat=${lat}&lon=${lon}&zoom=18&addressdetails=1`);
        const data = await response.json();
        if (data && data.display_name) {
          const addressOutput = document.getElementById('gps-address-output');
          if (addressOutput) {
            addressOutput.innerHTML = `<strong>Detected Location:</strong> ${data.display_name}`;
            addressOutput.style.color = '#10b981'; // Success Green
          }
        }
      } catch (e) {
        console.warn('Reverse geocoding failed', e);
      }
    }, err => {
      console.warn('Geolocation permission denied or failed.', err);
    });
  }
</script>

<body>

  <%- include('partials/header2') %>

    <div class="form-wrapper">
      <div class="top-header">
        <div>
          <h1>Conduct Inspection</h1>
          <p>Complete the hygiene inspection checklist</p>
        </div>
        <span class="badge <%= scoreBadge %>">Current Score: <%= hygieneScore %>/5.0</span>
      </div>

      <form action="/inspection/submit/<%= inspection.id %>" method="POST" enctype="multipart/form-data">

        <!-- Restaurant Info -->
        <div class="card">
          <div class="card-header">
            <i data-lucide="building-2" class="icon blue"></i>
            <div>
              <h2>
                <%= restaurant.name %>
              </h2>
              <p>License: <%= restaurant.license_number %>
              </p>
            </div>
          </div>
          <div class="card-content">
            <p><i data-lucide="map-pin"></i>
              <%= restaurant.address %>
            </p>
            <p><i data-lucide="phone"></i>
              <%= restaurant.phone %>
            </p>
            <p><i data-lucide="mail"></i>
              <%= restaurant.email %>
            </p>
            <p><i data-lucide="calendar"></i> Scheduled: <%= inspection.scheduled_date %>
            </p>
          </div>
        </div>

        <!-- Checklist -->
        <% Object.entries(checklistSchema).forEach(([section, items])=> { %>
          <div class="card">
            <div class="card-header">
              <h3>
                <%= sectionLabels[section] %>
              </h3>
              <p>Check all items that meet the hygiene standards</p>
            </div>
            <div class="card-content">
              <% Object.entries(items).forEach(([key, label])=> { %>
                <label class="checkbox-row">
                  <input type="checkbox" name="checklist[<%= section %>][<%= key %>]" />
                  <span>
                    <%= label %>
                  </span>
                </label>
                <% }) %>
            </div>
          </div>
          <% }) %>

            <!-- Notes -->
            <div class="card">
              <div class="card-header">
                <h3>Additional Notes</h3>
                <p>Add any observations or recommendations</p>
              </div>
              <div class="card-content">
                <textarea name="notes" rows="5" placeholder="Enter notes..."></textarea>
              </div>
            </div>

            <div class="location-card">
              <h3>📍 Inspection Location Audit</h3>
              <p style="color: #64748b; font-size: 0.9rem; margin-bottom: 12px;">Your current GPS location is
                permanently recorded against this inspection report.</p>
              <div style="display: flex; gap: 12px; margin-bottom: 12px;">
                <div class="location-group" style="flex: 1;">
                  <label for="latitude">Latitude</label>
                  <input type="text" id="latitude" name="latitude" readonly style="background: #f1f5f9;" />
                </div>
                <div class="location-group" style="flex: 1;">
                  <label for="longitude">Longitude</label>
                  <input type="text" id="longitude" name="longitude" readonly style="background: #f1f5f9;" />
                </div>
              </div>
              <p id="gps-address-output" style="font-size: 0.95rem; color: #f59e0b;">Fetching live address from
                satellite...</p>
            </div>


            <div class="form-group">

            </div>

            <!-- Images -->
            <div class="card">
              <div class="card-header">
                <h3>Supporting Images</h3>
                <p>Upload photos for your inspection</p>
              </div>
              <div class="card-content drop-area">
                <i data-lucide="camera" class="icon large gray"></i>
                <p>Click to upload or drag and drop</p>
                <!-- Live Camera Integration Component -->
                <div id="live-camera-module"
                  style="display: none; background: #000; border-radius: 12px; overflow: hidden; position: relative; width: 100%; margin-top: 16px; margin-bottom: 16px;">
                  <video id="camera-stream" autoplay playsinline
                    style="width: 100%; height: auto; display: block;"></video>
                  <button type="button" id="webrtc-capture-btn"
                    style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: #ef4444; color: white; border: 4px solid rgba(255,255,255,0.4); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.5);">
                    <i data-lucide="camera" style="width: 24px; height: 24px;"></i>
                  </button>
                  <button type="button" id="webrtc-close-btn"
                    style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.5); color: white; border: none; padding: 8px; border-radius: 8px; cursor: pointer;">
                    X
                  </button>
                </div>

                <canvas id="camera-canvas" style="display: none;"></canvas>

                <div id="camera-preview" style="display: none; margin-top: 16px; text-align: center;">
                  <img id="preview-img"
                    style="width: 100%; max-width: 400px; border-radius: 8px; border: 2px solid #10b981;" />
                  <p style="color: #10b981; font-weight: bold; margin-top: 8px;">✅ Image Captured!</p>
                  <button type="button" id="webrtc-retake-btn" class="btn outline" style="margin-top: 8px;">Retake
                    Photo</button>
                </div>

                <input type="file" name="images" id="cameraInput" multiple accept="image/*" style="display: none;" />

                <div style="display: flex; gap: 12px; margin-top: 12px;">
                  <button type="button" class="btn primary" id="open-live-camera-btn" style="flex: 1;">
                    🔴 Open Live Camera
                  </button>
                  <button type="button" class="btn outline" onclick="document.getElementById('cameraInput').click()"
                    style="flex: 1;">
                    📁 Select from Gallery
                  </button>
                </div>
              </div>
            </div>

            <!-- Submit -->
            <div class="submit-actions">
              <button type="button" class="btn outline" onclick="window.history.back()">Cancel</button>
              <button type="submit" class="btn primary">
                <i data-lucide="check-circle"></i> Submit Report
              </button>
            </div>

      </form>

    </div>

    <script>
      lucide.createIcons();

      // WebRTC Live Camera Logic
      const openLiveCameraBtn = document.getElementById('open-live-camera-btn');
      const liveCameraModule = document.getElementById('live-camera-module');
      const cameraStream = document.getElementById('camera-stream');
      const captureBtn = document.getElementById('webrtc-capture-btn');
      const closeBtn = document.getElementById('webrtc-close-btn');
      const canvas = document.getElementById('camera-canvas');
      const cameraInput = document.getElementById('cameraInput');
      const cameraPreview = document.getElementById('camera-preview');
      const previewImg = document.getElementById('preview-img');
      const retakeBtn = document.getElementById('webrtc-retake-btn');

      let mediaStream = null;

      async function startCamera() {
        try {
          mediaStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
          cameraStream.srcObject = mediaStream;
          liveCameraModule.style.display = 'block';
          openLiveCameraBtn.style.display = 'none';
          cameraPreview.style.display = 'none';
        } catch (err) {
          alert('Could not access camera. Please check your browser permissions.');
          console.error(err);
        }
      }

      function stopCamera() {
        if (mediaStream) {
          mediaStream.getTracks().forEach(track => track.stop());
          mediaStream = null;
        }
        liveCameraModule.style.display = 'none';
        openLiveCameraBtn.style.display = 'block';
      }

      openLiveCameraBtn.addEventListener('click', startCamera);
      closeBtn.addEventListener('click', stopCamera);
      retakeBtn.addEventListener('click', startCamera);

      captureBtn.addEventListener('click', () => {
        canvas.width = cameraStream.videoWidth;
        canvas.height = cameraStream.videoHeight;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(cameraStream, 0, 0, canvas.width, canvas.height);

        canvas.toBlob(blob => {
          const file = new File([blob], `inspection_snapshot_${Date.now()}.jpg`, { type: 'image/jpeg' });
          const dt = new DataTransfer();
          dt.items.add(file);
          cameraInput.files = dt.files;

          previewImg.src = URL.createObjectURL(blob);
          stopCamera();
          cameraPreview.style.display = 'block';
          openLiveCameraBtn.style.display = 'none';
        }, 'image/jpeg', 0.9);
      });
    </script>
</body>

</html>