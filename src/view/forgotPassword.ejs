<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Forgot Password – Food Hygiene Platform</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Segoe UI', sans-serif;
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #1e3a8a 0%, #0ea5e9 100%);
        }

        .card {
            background: white;
            border-radius: 16px;
            padding: 40px;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
            text-align: center;
        }

        .icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
        }

        .icon svg {
            color: white;
            width: 32px;
            height: 32px;
        }

        h1 {
            font-size: 1.6rem;
            color: #1f2937;
            margin-bottom: 8px;
        }

        p.subtitle {
            font-size: 0.95rem;
            color: #6b7280;
            margin-bottom: 28px;
            line-height: 1.5;
        }

        .form-group {
            text-align: left;
            margin-bottom: 20px;
        }

        label {
            display: block;
            font-weight: 600;
            color: #374151;
            margin-bottom: 6px;
            font-size: 0.9rem;
        }

        input[type="email"] {
            width: 100%;
            padding: 12px 16px;
            border: 1px solid #d1d5db;
            border-radius: 8px;
            font-size: 0.95rem;
            transition: border 0.2s;
            outline: none;
        }

        input[type="email"]:focus {
            border-color: #1d4ed8;
        }

        .role-selector {
            display: flex;
            gap: 8px;
            flex-wrap: wrap;
            margin-bottom: 20px;
        }

        .role-btn {
            flex: 1;
            padding: 10px;
            border: 2px solid #e5e7eb;
            border-radius: 8px;
            cursor: pointer;
            background: white;
            font-size: 0.82rem;
            font-weight: 600;
            color: #374151;
            transition: all 0.2s;
        }

        .role-btn.active {
            border-color: #1d4ed8;
            background: #eff6ff;
            color: #1d4ed8;
        }

        .btn-submit {
            width: 100%;
            padding: 14px;
            background: linear-gradient(135deg, #1d4ed8, #0ea5e9);
            color: white;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            transition: opacity 0.2s;
        }

        .btn-submit:hover {
            opacity: 0.9;
        }

        .alert {
            padding: 12px 16px;
            border-radius: 8px;
            margin-bottom: 20px;
            font-size: 0.9rem;
            text-align: left;
        }

        .alert-error {
            background: #fee2e2;
            color: #b91c1c;
            border-left: 4px solid #ef4444;
        }

        .alert-success {
            background: #d1fae5;
            color: #065f46;
            border-left: 4px solid #10b981;
        }

        .back-link {
            display: block;
            margin-top: 20px;
            color: #6b7280;
            font-size: 0.9rem;
            text-decoration: none;
        }

        .back-link:hover {
            color: #1d4ed8;
        }
    </style>
</head>

<body>
    <div class="card">
        <div class="icon">
            <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor"
                stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round"
                    d="M15 7a2 2 0 012 2m4 0a6 6 0 01-7.743 5.743L11 17H9v2H7v2H4a1 1 0 01-1-1v-2.586a1 1 0 01.293-.707l5.964-5.964A6 6 0 1121 9z" />
            </svg>
        </div>

        <h1>Forgot Password?</h1>
        <p class="subtitle">No worries! Enter your email and we'll generate a secure reset link for you.</p>

        <% if (typeof error !=='undefined' ) { %>
            <div class="alert alert-error">⚠️ <%= error %>
            </div>
            <% } %>
                <% if (typeof success !=='undefined' ) { %>
                    <div class="alert alert-success">✅ <%= success %>
                    </div>
                    <% } %>

                        <form action="/forgot-password" method="POST">
                            <!-- Role Selector -->
                            <p
                                style="font-weight:600;color:#374151;text-align:left;margin-bottom:8px;font-size:0.9rem;">
                                I am a...</p>
                            <div class="role-selector">
                                <button type="button" class="role-btn active" data-role="user"
                                    onclick="selectRole(this)">👤 User</button>
                                <button type="button" class="role-btn" data-role="inspector"
                                    onclick="selectRole(this)">🔍 Inspector</button>
                                <button type="button" class="role-btn" data-role="admin" onclick="selectRole(this)">🛡️
                                    Admin</button>
                            </div>
                            <input type="hidden" name="role" id="roleInput" value="user" />

                            <div class="form-group">
                                <label for="email">Email Address</label>
                                <input type="email" id="email" name="email" placeholder="Enter your email" required />
                            </div>

                            <button type="submit" class="btn-submit">Send Reset Link</button>
                        </form>

                        <a href="/" class="back-link">← Back to Home</a>
    </div>

    <script>
        function selectRole(btn) {
            document.querySelectorAll('.role-btn').forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            document.getElementById('roleInput').value = btn.dataset.role;
        }
    </script>
</body>

</html>