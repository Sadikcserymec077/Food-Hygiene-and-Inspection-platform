<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <title>File Complaint</title>
  <link rel="stylesheet" href="/css/fileComplaint.css">
</head>

<body>
  <%- include('../partials/header3') %>

    <div class="complaint-container">
      <div class="form-wrapper">
        <h2>📣 File a Complaint</h2>
        <p class="restaurant-name">Against Restaurant: <strong>
            <%= restaurant.name %>
          </strong></p>

        <form action="/user/complaint/<%= restaurantId %>" method="POST" enctype="multipart/form-data"
          class="complaint-form">
          <label for="subject">Complaint Subject:</label>
          <input type="text" id="subject" name="subject" placeholder="E.g., Unhygienic kitchen practices" required>

          <label for="description">Complaint Description:</label>
          <textarea id="description" name="description" rows="6"
            placeholder="Describe the issue clearly with details..." required></textarea>

          <label>Upload Images (optional):</label>
          <!-- Live Camera Integration Component -->
          <div id="live-camera-module"
            style="display: none; background: #000; border-radius: 8px; overflow: hidden; position: relative; width: 100%; margin-top: 8px; margin-bottom: 16px;">
            <video id="camera-stream" autoplay playsinline style="width: 100%; height: auto; display: block;"></video>
            <button type="button" id="webrtc-capture-btn"
              style="position: absolute; bottom: 20px; left: 50%; transform: translateX(-50%); background: #ef4444; color: white; border: 4px solid rgba(255,255,255,0.4); width: 60px; height: 60px; border-radius: 50%; display: flex; align-items: center; justify-content: center; cursor: pointer; box-shadow: 0 4px 10px rgba(0,0,0,0.5); z-index: 10;">
              📸
            </button>
            <button type="button" id="webrtc-close-btn"
              style="position: absolute; top: 10px; right: 10px; background: rgba(0,0,0,0.5); color: white; border: none; padding: 8px; border-radius: 8px; cursor: pointer; z-index: 10;">
              Done
            </button>
          </div>

          <canvas id="camera-canvas" style="display: none;"></canvas>

          <!-- Thumbnail Gallery -->
          <div id="camera-gallery"
            style="display: grid; grid-template-columns: repeat(auto-fill, minmax(80px, 1fr)); gap: 8px; margin-top: 16px;">
          </div>

          <input type="file" id="images" name="images" accept="image/*" style="display: none;" multiple>

          <div style="display: flex; gap: 12px; margin-top: 4px; margin-bottom: 16px;">
            <button type="button" id="open-live-camera-btn"
              style="flex: 1; padding: 12px; background: #3b82f6; color: white; border: none; border-radius: 6px; cursor: pointer; font-weight: bold;">
              🔴 Open Live Camera
            </button>
            <button type="button" onclick="document.getElementById('images').click()"
              style="flex: 1; padding: 12px; background: white; border: 1px solid #cbd5e1; border-radius: 6px; cursor: pointer; font-weight: bold;">
              📁 Select from Gallery
            </button>
          </div>

          <label class="anonymous-check">
            <input type="checkbox" name="anonymous"> Submit anonymously
          </label>

          <div class="guidelines">
            <h4>📝 Complaint Guidelines</h4>
            <ul>
              <li>✅ Be clear, specific, and factual</li>
              <li>🕒 Mention dates, times, and observations</li>
              <li>🚫 Avoid offensive or abusive language</li>
              <li>⏱️ Complaints are reviewed within 2–3 working days</li>
            </ul>
          </div>

          <button type="submit" class="submit-btn">Submit Complaint</button>
        </form>
      </div>
    </div>

    <script>
      // WebRTC Live Camera Logic
      const openLiveCameraBtn = document.getElementById('open-live-camera-btn');
      const liveCameraModule = document.getElementById('live-camera-module');
      const cameraStream = document.getElementById('camera-stream');
      const captureBtn = document.getElementById('webrtc-capture-btn');
      const closeBtn = document.getElementById('webrtc-close-btn');
      const canvas = document.getElementById('camera-canvas');
      const cameraInput = document.getElementById('images');
      const gallery = document.getElementById('camera-gallery');

      let mediaStream = null;
      let capturedFiles = [];

      async function startCamera() {
        try {
          mediaStream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: 'environment' } });
          cameraStream.srcObject = mediaStream;
          liveCameraModule.style.display = 'block';
          openLiveCameraBtn.style.display = 'none';
        } catch (err) {
          alert('Could not access camera. Please check your browser permissions.');
          console.error(err);
        }
      }

      function stopCamera() {
        if (mediaStream) {
          mediaStream.getTracks().forEach(track => track.stop());
          mediaStream = null;
        }
        liveCameraModule.style.display = 'none';
        openLiveCameraBtn.style.display = 'block';
      }

      function updateFileInput() {
        const dt = new DataTransfer();
        capturedFiles.forEach(file => dt.items.add(file));
        cameraInput.files = dt.files;
      }

      function addThumbnail(file) {
        const wrapper = document.createElement('div');
        wrapper.style.position = 'relative';

        const img = document.createElement('img');
        img.src = URL.createObjectURL(file);
        img.style.width = '100%';
        img.style.height = '80px';
        img.style.objectFit = 'cover';
        img.style.borderRadius = '8px';
        img.style.border = '1px solid #e2e8f0';

        const removeBtn = document.createElement('button');
        removeBtn.innerHTML = '×';
        removeBtn.style.position = 'absolute';
        removeBtn.style.top = '-5px';
        removeBtn.style.right = '-5px';
        removeBtn.style.background = '#ef4444';
        removeBtn.style.color = 'white';
        removeBtn.style.border = 'none';
        removeBtn.style.borderRadius = '50%';
        removeBtn.style.width = '20px';
        removeBtn.style.height = '20px';
        removeBtn.style.display = 'flex';
        removeBtn.style.alignItems = 'center';
        removeBtn.style.justifyContent = 'center';
        removeBtn.style.cursor = 'pointer';
        removeBtn.style.fontSize = '14px';

        removeBtn.onclick = () => {
          capturedFiles = capturedFiles.filter(f => f !== file);
          updateFileInput();
          wrapper.remove();
        };

        wrapper.appendChild(img);
        wrapper.appendChild(removeBtn);
        gallery.appendChild(wrapper);
      }

      openLiveCameraBtn.addEventListener('click', startCamera);
      closeBtn.addEventListener('click', stopCamera);

      captureBtn.addEventListener('click', () => {
        canvas.width = cameraStream.videoWidth;
        canvas.height = cameraStream.videoHeight;
        const ctx = canvas.getContext('2d');
        ctx.drawImage(cameraStream, 0, 0, canvas.width, canvas.height);

        // --- Phase 8: Image Quality Guardrail ---
        const quality = ImageQualityGuard.analyze(canvas);
        if (!quality.isGood) {
          if (!confirm(`${quality.reason}\n\nDo you want to keep this photo anyway?`)) {
            return; // Cancel capture
          }
        }

        canvas.toBlob(blob => {
          const file = new File([blob], `complaint_snapshot_${Date.now()}.jpg`, { type: 'image/jpeg' });
          capturedFiles.push(file);
          updateFileInput();
          addThumbnail(file);

          // Visual feedback
          captureBtn.style.background = '#10b981';
          setTimeout(() => captureBtn.style.background = '#ef4444', 300);
        }, 'image/jpeg', 0.9);
      });
    </script>
    <script src="/js/imageQualityGuard.js"></script>
</body>

</html>