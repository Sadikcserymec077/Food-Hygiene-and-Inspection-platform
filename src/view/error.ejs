<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Error | FSSAI Inspector Hub</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: 'Segoe UI', sans-serif;
      background: #f4f6f9;
      display: flex;
      align-items: center;
      justify-content: center;
      min-height: 100vh;
    }
    .error-box {
      background: #fff;
      border-radius: 12px;
      padding: 50px 40px;
      text-align: center;
      max-width: 480px;
      width: 90%;
      box-shadow: 0 4px 24px rgba(0,0,0,0.08);
    }
    .error-icon {
      font-size: 60px;
      margin-bottom: 20px;
    }
    h1 {
      font-size: 28px;
      color: #e53e3e;
      margin-bottom: 12px;
    }
    p {
      font-size: 16px;
      color: #555;
      margin-bottom: 28px;
      line-height: 1.6;
    }
    a {
      display: inline-block;
      background: #2b6cb0;
      color: #fff;
      padding: 12px 28px;
      border-radius: 8px;
      text-decoration: none;
      font-size: 15px;
      transition: background 0.2s;
    }
    a:hover { background: #2c5282; }
  </style>
</head>
<body>
  <div class="error-box">
    <div class="error-icon">⚠️</div>
    <h1>Something went wrong</h1>
    <p><%= message || 'An unexpected error occurred. Please try again.' %></p>
    <a href="javascript:history.back()">← Go Back</a>
  </div>
</body>
</html>
